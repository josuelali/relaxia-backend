<!DOCTYPE html>
<html lang="es">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta charset="utf-8" />
    <title>Planes - RELAXIA</title>

    <style>
      .pricing-container {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 2rem;
        padding: 2rem;
      }
      .plan-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 2rem;
        width: 300px;
        text-align: center;
        background: #fff;
      }
      .price {
        font-size: 2.5rem;
        color: #2563eb;
        margin: 1rem 0;
      }
      .features {
        list-style: none;
        padding: 0;
      }
      .features li {
        margin: 0.5rem 0;
      }
      .subscribe-btn {
        background: #2563eb;
        color: white;
        border: none;
        padding: 1rem 2rem;
        border-radius: 6px;
        cursor: pointer;
        margin-top: 1rem;
        width: 100%;
        font-weight: 700;
      }
      .subscribe-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }
      .popular {
        border: 3px solid #2563eb;
        position: relative;
      }
      .badge {
        background: #2563eb;
        color: white;
        padding: 0.5rem 0.9rem;
        text-align: center;
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        border-radius: 15px;
        font-size: 0.85rem;
        font-weight: bold;
      }
      .note {
        text-align: center;
        font-size: 13px;
        color: #6b7280;
        margin-top: -10px;
      }
    </style>
  </head>

  <body>
    <p class="note">Planes de suscripción (modo prueba)</p>

    <div class="pricing-container">
      <div class="plan-card">
        <h2>Plan Básico</h2>
        <div class="price">€9,99/mes</div>
        <ul class="features">
          <li>✅ 50 análisis de productos/mes</li>
          <li>✅ Generación de contenido básico</li>
          <li>✅ Productos trending semanales</li>
          <li>✅ Soporte por email</li>
          <li>❌ Análisis de competencia</li>
        </ul>
        <button class="subscribe-btn" onclick="subscribe('basic', this)">Empezar ahora</button>
      </div>

      <div class="plan-card popular">
        <div class="badge">MÁS POPULAR</div>
        <h2>Plan Pro</h2>
        <div class="price">€29,99/mes</div>
        <ul class="features">
          <li>✅ 200 análisis de productos/mes</li>
          <li>✅ Contenido ilimitado con IA</li>
          <li>✅ Productos trending diarios</li>
          <li>✅ Análisis completo de competencia</li>
          <li>✅ Sugerencias de precios</li>
          <li>✅ Soporte prioritario</li>
        </ul>
        <button class="subscribe-btn" onclick="subscribe('pro', this)">Empezar ahora</button>
      </div>

      <div class="plan-card">
        <h2>Plan Enterprise</h2>
        <div class="price">€99,99/mes</div>
        <ul class="features">
          <li>✅ Análisis ilimitados</li>
          <li>✅ Integración avanzada</li>
          <li>✅ Reportes personalizados</li>
          <li>✅ Consultoría 1-a-1</li>
          <li>✅ Soporte 24/7</li>
        </ul>
        <button class="subscribe-btn" onclick="subscribe('enterprise', this)">Contactar / Suscribirme</button>
      </div>
    </div>

    <script src="https://js.stripe.com/v3/"></script>
    <script>
      // Stripe public key (pk_test...) viene del servidor.
      const stripeKey = "<%= stripeKey || '' %>";

      async function subscribe(plan, btn) {
        if (!stripeKey) {
          alert("Falta STRIPE_PUBLISHABLE_KEY en el servidor. Revisa Replit Secrets.");
          return;
        }

        btn.disabled = true;
        btn.textContent = "Abriendo pago...";

        try {
          // Llama a tu backend Node (POST /api/checkout) para crear la sesión
          const response = await fetch("/api/checkout", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ plan }),
          });

          const data = await response.json();

          if (!response.ok) {
            console.error("Checkout error:", data);
            alert(data.error || "Error al iniciar el pago.");
            return;
          }

          if (!data.url) {
            console.error("Respuesta sin url:", data);
            alert("No recibí la URL de pago. Revisa el backend.");
            return;
          }

          // Redirige a Stripe Checkout
          window.location.href = data.url;
        } catch (err) {
          console.error(err);
          alert("Error de red. Intenta de nuevo.");
        } finally {
          btn.disabled = false;
          btn.textContent = plan === "enterprise" ? "Contactar / Suscribirme" : "Empezar ahora";
        }
      }
    </script>
  </body>
</html>
