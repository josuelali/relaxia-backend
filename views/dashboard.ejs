
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Relax-IA</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f5f7fa;
      color: #333;
    }
    
    .header {
      background: #2563eb;
      color: white;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .user-info {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    
    .user-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
    }
    
    .container {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    
    .tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 2rem;
      margin-bottom: 2rem;
    }
    
    .tool-card {
      background: white;
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
    
    .tool-card h3 {
      color: #2563eb;
      margin-bottom: 1rem;
      font-size: 1.25rem;
    }
    
    .form-group {
      margin-bottom: 1rem;
    }
    
    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }
    
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 1rem;
    }
    
    .btn {
      background: #2563eb;
      color: white;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: 6px;
      cursor: pointer;
      font-size: 1rem;
      transition: background 0.3s;
    }
    
    .btn:hover {
      background: #1d4ed8;
    }
    
    .btn:disabled {
      background: #94a3b8;
      cursor: not-allowed;
    }
    
    .result-box {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      padding: 1rem;
      margin-top: 1rem;
      white-space: pre-wrap;
      font-family: monospace;
      max-height: 300px;
      overflow-y: auto;
    }
    
    .loading {
      text-align: center;
      color: #64748b;
      font-style: italic;
    }
    
    .error {
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #dc2626;
    }
    
    .success {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      color: #166534;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Relax-IA Dashboard</h1>
    <div class="user-info">
      <% if (user.picture) { %>
        <img src="<%= user.picture %>" alt="Avatar" class="user-avatar">
      <% } %>
      <span>Hola, <%= user.name %></span>
      <a href="/logout" style="color: white; text-decoration: none; margin-left: 1rem;">Salir</a>
    </div>
  </div>

  <div class="container">
    <div class="tools-grid">
      <!-- Análisis de Productos -->
      <div class="tool-card">
        <h3>🔍 Análisis de Productos</h3>
        <form id="analyzeForm">
          <div class="form-group">
            <label>Nombre del Producto:</label>
            <input type="text" id="productName" required placeholder="Ej: Smartwatch fitness">
          </div>
          <div class="form-group">
            <label>Categoría:</label>
            <select id="category" required>
              <option value="">Seleccionar categoría</option>
              <option value="tecnologia">Tecnología</option>
              <option value="hogar">Hogar y Jardín</option>
              <option value="deportes">Deportes y Fitness</option>
              <option value="belleza">Belleza y Cuidado</option>
              <option value="ropa">Ropa y Accesorios</option>
              <option value="mascotas">Mascotas</option>
              <option value="bebes">Bebés y Niños</option>
            </select>
          </div>
          <button type="submit" class="btn">Analizar Producto</button>
        </form>
        <div id="analyzeResult" class="result-box" style="display: none;"></div>
      </div>

      <!-- Generación de Contenido -->
      <div class="tool-card">
        <h3>✍️ Generador de Contenido</h3>
        <form id="contentForm">
          <div class="form-group">
            <label>Producto:</label>
            <input type="text" id="contentProduct" required placeholder="Nombre del producto">
          </div>
          <div class="form-group">
            <label>Características principales:</label>
            <textarea id="features" rows="3" placeholder="Ej: Resistente al agua, batería 7 días, monitor cardíaco"></textarea>
          </div>
          <div class="form-group">
            <label>Público objetivo:</label>
            <input type="text" id="targetAudience" placeholder="Ej: Jóvenes de 18-35 años amantes del fitness">
          </div>
          <button type="submit" class="btn">Generar Contenido</button>
        </form>
        <div id="contentResult" class="result-box" style="display: none;"></div>
      </div>

      <!-- Productos Trending -->
      <div class="tool-card">
        <h3>🔥 Productos Trending</h3>
        <form id="trendingForm">
          <div class="form-group">
            <label>Nicho de mercado:</label>
            <select id="niche" required>
              <option value="">Seleccionar nicho</option>
              <option value="tecnologia">Tecnología</option>
              <option value="fitness">Fitness y Salud</option>
              <option value="hogar">Hogar Inteligente</option>
              <option value="mascotas">Productos para Mascotas</option>
              <option value="cocina">Cocina y Utensilios</option>
              <option value="automovil">Accesorios de Auto</option>
              <option value="belleza">Belleza y Cuidado</option>
            </select>
          </div>
          <button type="submit" class="btn">Buscar Tendencias</button>
        </form>
        <div id="trendingResult" class="result-box" style="display: none;"></div>
      </div>

      <!-- Análisis de Competencia -->
      <div class="tool-card">
        <h3>🎯 Análisis de Competencia</h3>
        <form id="competitorForm">
          <div class="form-group">
            <label>Producto a analizar:</label>
            <input type="text" id="compProduct" required placeholder="Nombre del producto">
          </div>
          <div class="form-group">
            <label>URL del competidor (opcional):</label>
            <input type="url" id="compUrl" placeholder="https://ejemplo.com/producto">
          </div>
          <button type="submit" class="btn">Analizar Competencia</button>
        </form>
        <div id="competitorResult" class="result-box" style="display: none;"></div>
      </div>
    </div>
  </div>

  <script>
    // Función auxiliar para mostrar loading
    function showLoading(resultId) {
      const resultDiv = document.getElementById(resultId);
      resultDiv.style.display = 'block';
      resultDiv.className = 'result-box loading';
      resultDiv.textContent = 'Analizando con IA... ⏳';
    }

    // Función auxiliar para mostrar resultados
    function showResult(resultId, data, isError = false) {
      const resultDiv = document.getElementById(resultId);
      resultDiv.className = isError ? 'result-box error' : 'result-box success';
      resultDiv.textContent = typeof data === 'string' ? data : JSON.stringify(data, null, 2);
    }

    // Análisis de productos
    document.getElementById('analyzeForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const productName = document.getElementById('productName').value;
      const category = document.getElementById('category').value;
      
      showLoading('analyzeResult');
      
      try {
        const response = await fetch('/api/analyze-product', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productName, category })
        });
        
        const data = await response.json();
        showResult('analyzeResult', data.analysis);
      } catch (error) {
        showResult('analyzeResult', 'Error al analizar producto', true);
      }
    });

    // Generación de contenido
    document.getElementById('contentForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const productName = document.getElementById('contentProduct').value;
      const features = document.getElementById('features').value;
      const targetAudience = document.getElementById('targetAudience').value;
      
      showLoading('contentResult');
      
      try {
        const response = await fetch('/api/generate-content', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productName, features, targetAudience })
        });
        
        const data = await response.json();
        showResult('contentResult', data.content);
      } catch (error) {
        showResult('contentResult', 'Error al generar contenido', true);
      }
    });

    // Productos trending
    document.getElementById('trendingForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const niche = document.getElementById('niche').value;
      
      showLoading('trendingResult');
      
      try {
        const response = await fetch('/api/trending-products', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ niche })
        });
        
        const data = await response.json();
        showResult('trendingResult', data.products);
      } catch (error) {
        showResult('trendingResult', 'Error al buscar productos trending', true);
      }
    });

    // Análisis de competencia
    document.getElementById('competitorForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const productName = document.getElementById('compProduct').value;
      const productUrl = document.getElementById('compUrl').value;
      
      showLoading('competitorResult');
      
      try {
        const response = await fetch('/api/competitor-analysis', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productName, productUrl })
        });
        
        const data = await response.json();
        showResult('competitorResult', data.analysis);
      } catch (error) {
        showResult('competitorResult', 'Error al analizar competencia', true);
      }
    });
  </script>
</body>
</html>
